// Progress-O-Meter — PostgreSQL schema.
// Optimized for the two hot query paths:
//   1. e1RM history per exercise  → WorkoutSet(exerciseId, performedAt) index,
//      e1rm denormalized at write time so charting never recomputes.
//   2. Session feeds by user/date → Workout(userId, date), CardioSession(userId, date).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  restHr         Int              @default(60)
  maxHr          Int              @default(190)
  createdAt      DateTime         @default(now())
  workouts       Workout[]
  cardioSessions CardioSession[]
  personalRecords PersonalRecord[]
}

model MuscleGroup {
  id        String     @id @default(cuid())
  slug      String     @unique // "chest", "hams-glutes", ...
  name      String
  accent    String // neon hex used by the 3D zone + UI
  sortOrder Int        @default(0)
  exercises Exercise[]
}

model Exercise {
  id              String           @id @default(cuid())
  slug            String           @unique // "flat-barbell-bench-press"
  name            String
  muscleGroup     MuscleGroup      @relation(fields: [muscleGroupId], references: [id], onDelete: Cascade)
  muscleGroupId   String
  isBodyweight    Boolean          @default(false)
  sets            WorkoutSet[]
  personalRecords PersonalRecord[]

  @@unique([muscleGroupId, name])
  @@index([muscleGroupId])
}

model Workout {
  id     String       @id @default(cuid())
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  date   DateTime     @db.Date
  notes  String?
  sets   WorkoutSet[]

  @@unique([userId, date]) // one training-day container per calendar day
  @@index([userId, date(sort: Desc)])
}

enum SetTag {
  WARMUP
  WORKING
  DROP
  FAILURE
}

model WorkoutSet {
  id          String   @id @default(cuid())
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId   String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId  String
  setNumber   Int
  weightKg    Decimal  @db.Decimal(6, 2)
  reps        Int
  tag         SetTag   @default(WORKING)
  /// Epley e1RM, denormalized at write time for O(rows) chart reads
  e1rm        Decimal  @db.Decimal(6, 2)
  performedAt DateTime @default(now())

  @@index([exerciseId, performedAt])
  @@index([workoutId, setNumber])
}

model PersonalRecord {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  e1rm       Decimal  @db.Decimal(6, 2)
  weightKg   Decimal  @db.Decimal(6, 2)
  reps       Int
  achievedAt DateTime @default(now())

  @@unique([userId, exerciseId]) // upserted: always the current best
  @@index([userId, achievedAt(sort: Desc)])
}

enum CardioActivity {
  RUNNING
  CYCLING
  SWIMMING
  ROWING
}

enum RunType {
  SPRINTS
  INTERVALS
  LONG_RUN
  TEMPO
  RECOVERY
}

model CardioSession {
  id             String         @id @default(cuid())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  activity       CardioActivity
  runType        RunType? // only when activity = RUNNING
  date           DateTime       @db.Date
  durationSec    Int
  distanceM      Int
  avgHr          Int?
  maxHr          Int?
  /// TRIMP-based score, denormalized at write time
  relativeEffort Int
  notes          String?
  splits         CardioSplit[]
  createdAt      DateTime       @default(now())

  @@index([userId, date(sort: Desc)])
  @@index([userId, activity, date(sort: Desc)])
}

model CardioSplit {
  id          String        @id @default(cuid())
  session     CardioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  index       Int // 1-based km marker
  distanceM   Int
  durationSec Float
  avgHr       Int?

  @@unique([sessionId, index])
}
