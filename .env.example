# ── MongoDB (Atlas) ───────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com, then:
#   Database Access → add a user;  Network Access → allow your IP (or 0.0.0.0/0 for dev)
#   Connect → Drivers → copy the connection string and add the db name (/gymbro).
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/gymbro?retryWrites=true&w=majority"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-me-with-a-long-random-string"
# In production set this to your deployed URL, e.g. https://gymbro.vercel.app
AUTH_URL="http://localhost:3000"

# ── Optional: Google OAuth ────────────────────────────────────────
# Leave blank to disable the "Continue with Google" button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
